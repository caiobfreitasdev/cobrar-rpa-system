# Caminho do arquivo Excel de contas a receber (aba BASE)
EXCEL_PATH=C:\caminho\para\contas_a_receber.xlsx

# Identidade da instancia (aparece no titulo/subtitulo do app).
# Para varias carteiras: uma pasta por empresa, cada uma com seu .env.
APP_CARTEIRA=Sinergas
# Porta local; mude (ex: 8757) para rodar duas instancias ao mesmo tempo.
APP_PORT=8756

# Microsoft Graph API - envio de e-mail (client credentials / app-only)
# App Registration precisa da permissao de APLICACAO Mail.Send (admin consent).
ID_CLIENT_ID=
ID_CLIENT_SECRET=
ID_CLIENT_TENANT=
# Caixa de e-mail remetente (UPN/endereco)
GRAPH_SENDER=no-reply@suaempresa.com.br
